# 1. Flutter SDK 포함 개발용 이미지
FROM ghcr.io/cirruslabs/flutter:stable

# 루트 권한 사용
USER root

WORKDIR /app

# 리눅스 빌드용 필수 패키지 (optional, desktop 빌드 대비)
RUN apt-get update && apt-get install -y \
    clang \
    cmake \
    ninja-build \
    pkg-config \
    libgtk-3-dev \
    liblzma-dev \
    && rm -rf /var/lib/apt/lists/*

# 소스 복사
COPY . .

# Flutter 의존성 설치
RUN flutter pub get

# 볼륨 마운트 후에도 컨테이너 기준으로 의존성 경로를 맞추기 위해 pub get 후 실행
CMD ["sh", "-c", "flutter pub get && exec flutter run -d web-server --web-port 80 --web-hostname 0.0.0.0"]