# 1. Flutter SDK 포함 개발용 이미지
FROM ghcr.io/cirruslabs/flutter:stable

# 루트 권한 사용
USER root

WORKDIR /app

# 리눅스 빌드용 필수 패키지 (optional, desktop 빌드 대비)
RUN apt-get update && apt-get install -y \
    clang \
    cmake \
    ninja-build \
    pkg-config \
    libgtk-3-dev \
    liblzma-dev \
    && rm -rf /var/lib/apt/lists/*

# 소스 복사
COPY . .

# Flutter 의존성 설치
RUN flutter pub get

# 웹 개발용 서버 실행 (팀원 브라우저 접속용)
CMD ["flutter", "run", "-d", "web-server", "--web-port", "80", "--web-hostname", "0.0.0.0"]