# 1. 빌드 단계 (리눅스 데스크톱 도구 풀세트 설치)
FROM ghcr.io/cirruslabs/flutter:stable AS build-stage

USER root
# 리눅스 실행 파일 빌드에 필수적인 5대장: clang, cmake, ninja, pkg-config, gtk
RUN apt-get update && apt-get install -y \
    clang \
    cmake \
    ninja-build \
    pkg-config \
    libgtk-3-dev \
    liblzma-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 리눅스 빌드 모드 활성화
RUN flutter config --enable-linux-desktop

# 소스 복사 및 패키지 설치 
COPY . .
RUN flutter pub get

# 🚩 웹이 아닌 '리눅스 실행 파일'로 빌드
RUN flutter build linux --release

# 2. 결과물 추출 단계
FROM alpine:latest
WORKDIR /output
# 빌드된 'bundle' 폴더(실행 파일과 필수 라이브러리 포함)를 통째로 복사
COPY --from=build-stage /app/build/linux/x64/release/bundle .

CMD ["ls", "-l"]